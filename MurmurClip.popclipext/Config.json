{
  "identifier": "men.helpall.murmurclip",
  "name": {
    "en": "MurmurClip Translate",
    "zh-hans": "MurmurClip 翻译助手"
  },
  "description": {
    "en": "Translate or correct selected text. Chinese to English translation, English grammar correction.",
    "zh-hans": "翻译或纠正选中文本。中文翻译为英文口语，英文语法纠正与口语化优化。"
  },
  "icon": "symbol:character.book.closed",
  "popclipVersion": 4151,
  "entitlements": ["network"],
  "options": [
    {
      "identifier": "sourceLanguage",
      "type": "multiple",
      "label": {
        "en": "Source Language",
        "zh-hans": "源语言"
      },
      "values": ["auto", "zh", "en", "ja", "ko", "fr", "de", "es"],
      "valueLabels": ["Auto Detect", "Chinese", "English", "Japanese", "Korean", "French", "German", "Spanish"],
      "defaultValue": "auto"
    },
    {
      "identifier": "targetLanguage",
      "type": "multiple",
      "label": {
        "en": "Target Language",
        "zh-hans": "目标语言"
      },
      "values": ["en", "zh", "ja", "ko", "fr", "de", "es"],
      "valueLabels": ["English", "Chinese", "Japanese", "Korean", "French", "German", "Spanish"],
      "defaultValue": "en"
    },
    {
      "identifier": "translationService",
      "type": "multiple",
      "label": {
        "en": "Translation Service",
        "zh-hans": "翻译服务"
      },
      "values": ["openai", "ollama", "anthropic"],
      "valueLabels": ["OpenAI Compatible", "Ollama (Local)", "Anthropic Claude"],
      "defaultValue": "openai"
    },
    {
      "identifier": "apiKey",
      "type": "secret",
      "label": {
        "en": "API Key",
        "zh-hans": "API 密钥"
      },
      "description": {
        "en": "Required for OpenAI / Anthropic services. Leave empty for Ollama.",
        "zh-hans": "OpenAI / Anthropic 服务需要填写。Ollama 无需填写。"
      }
    },
    {
      "identifier": "apiBaseUrl",
      "type": "string",
      "label": {
        "en": "API Base URL",
        "zh-hans": "API 地址"
      },
      "description": {
        "en": "Custom API endpoint. Default: OpenAI=https://api.openai.com/v1, Ollama=http://localhost:11434/v1, Anthropic=https://api.anthropic.com/v1",
        "zh-hans": "自定义 API 端点。默认：OpenAI=https://api.openai.com/v1，Ollama=http://localhost:11434/v1，Anthropic=https://api.anthropic.com/v1"
      },
      "defaultValue": ""
    },
    {
      "identifier": "modelName",
      "type": "string",
      "label": {
        "en": "Model Name",
        "zh-hans": "模型名称"
      },
      "description": {
        "en": "Model to use. e.g. gpt-4o-mini, llama3, claude-sonnet-4-20250514",
        "zh-hans": "使用的模型名称。例如 gpt-4o-mini、llama3、claude-sonnet-4-20250514"
      },
      "defaultValue": "gpt-4o-mini"
    }
  ],
  "requirements": ["text", "paste"],
  "after": "paste-result",
  "javascriptFile": "murmurclip.js"
}
